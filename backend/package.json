{
  "name": "dealer-site-backend",
  "version": "1.0.0",
  "description": "Express.js API for the Home Dealership platform",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:create": "node src/db/createDatabase.js",
    "db:init": "node src/db/init.js",
    "db:schema": "node -e \"const pool=require('./src/db/pool');const fs=require('fs');pool.query(fs.readFileSync('./src/db/schema.sql','utf8')).then(()=>{console.log('Schema applied');pool.end();}).catch(e=>{console.error(e);pool.end();})\"",
    "db:seed": "node -e \"const pool=require('./src/db/pool');const fs=require('fs');pool.query(fs.readFileSync('./src/db/seed.sql','utf8')).then(()=>{console.log('Seeded');pool.end();}).catch(e=>{console.error(e);pool.end();})\"",
    "db:verify": "node src/db/verify.js",
    "db:test": "node src/db/smokeTest.js",
    "db:reset": "node src/db/init.js",
    "db:migrate": "node -e \"const pool=require('./src/db/pool');const fs=require('fs');const path=require('path');const dir='./src/db/migrations';Promise.all(fs.readdirSync(dir).filter(f=>f.endsWith('.sql')).sort().map(f=>pool.query(fs.readFileSync(path.join(dir,f),'utf8')))).then(()=>{console.log('Migrations applied');pool.end();}).catch(e=>{console.error(e);pool.end();process.exit(1);})\""
  },
  "keywords": [
    "express",
    "postgresql",
    "api",
    "real-estate"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.11.0",
    "slugify": "^1.6.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
