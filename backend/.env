# =============================================
# DEALER SITE — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================

# --- Server ---
PORT=5000
NODE_ENV=production

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dealer_site
DB_USER=postgres
DB_PASSWORD=dealer2024

# --- JWT Authentication ---
JWT_SECRET=replace-with-a-long-random-secret-for-production
JWT_EXPIRES_IN=7d

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# --- CORS (Frontend URL) ---
CLIENT_URL=http://localhost:3000
