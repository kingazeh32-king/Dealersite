# =============================================
# DEALER SITE — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dealer_site
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# --- JWT Authentication ---
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# --- CORS (Frontend URL) ---
CLIENT_URL=http://localhost:3000

# --- Email Notifications (optional — logs to console if SMTP_HOST is empty) ---
# When configured, new inquiries and leads email NOTIFY_EMAIL.
# Gmail: use an App Password (https://support.google.com/accounts/answer/185833)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@dealersite.com
NOTIFY_EMAIL=info@dealersite.com
