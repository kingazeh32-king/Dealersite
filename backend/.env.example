# Server
PORT=5000
NODE_ENV=development

# Comma-separated frontend origins (required in production)
# Example after domain launch:
# CLIENT_URL=https://mobilehomesoftx.com,https://www.mobilehomesoftx.com,http://localhost:3000
CLIENT_URL=http://localhost:3000

# Auth — REQUIRED in production (long random string)
JWT_SECRET=replace-with-a-long-random-secret-for-production
JWT_EXPIRES_IN=7d

# PostgreSQL — either DATABASE_URL (Railway/Neon/Supabase) OR discrete fields
# DATABASE_URL=postgresql://user:pass@host:5432/dealer_site
# DB_SSL=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dealer_site
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# Local disk uploads (default). On Railway/Render, mount a volume and set:
# UPLOAD_DIR=/data/uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Optional S3-compatible object storage (AWS S3, Cloudflare R2, MinIO, etc.)
# When S3_BUCKET is set (or STORAGE_DRIVER=s3), uploads go to the bucket instead of disk.
# STORAGE_DRIVER=s3
# S3_BUCKET=your-bucket
# S3_REGION=auto
# S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://cdn.yourdomain.com
# S3_FORCE_PATH_STYLE=true

# Optional email notifications (inquiry + lead alerts)
# Recommended for mobilehomesoftx.com once the mailbox exists:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=info@mobilehomesoftx.com
# SMTP_PASS=your-app-password
# MAIL_FROM="Manufactured Mobile Homes of Texas <info@mobilehomesoftx.com>"
# NOTIFY_EMAIL=info@mobilehomesoftx.com
#
# Google Workspace / Gmail: use an App Password (not your normal login password).
# Microsoft 365: smtp.office365.com, port 587, STARTTLS.
# Resend/SendGrid/Mailgun also work — set their SMTP host and API credentials.
