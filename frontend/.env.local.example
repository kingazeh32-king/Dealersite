# Backend API base URL (include /api). Used for fetch + Next Image remotePatterns.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Optional: extra image hosts for Next/Image (comma-separated hostnames or full origins).
# Needed when using S3/R2/CDN for uploads, e.g.:
# NEXT_PUBLIC_IMAGE_HOSTS=cdn.yourdomain.com,pub-xxxxx.r2.dev

# Optional branding fallbacks when settings API is unavailable
# NEXT_PUBLIC_SITE_NAME=Manufactured Mobile Homes of Texas
# NEXT_PUBLIC_LOGO_SRC=/logo.svg
